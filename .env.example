# GlowUp AI — Environment Variables
# Copy to frontend/.env.local for dev, set in Vercel/Railway for production

# ---- Supabase ----
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_KEY=eyJh...           # Backend only (service_role key)

# ---- Stripe ----
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe CLI `stripe listen --forward-to ...`

# ---- Stripe Price IDs (create these in Stripe Dashboard) ----
# Products > Add Product > One-time payment
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=price_...

# ---- App ----
FRONTEND_URL=http://localhost:3000     # https://glowup-ai.vercel.app in prod
NEXT_PUBLIC_API_URL=http://localhost:8000
